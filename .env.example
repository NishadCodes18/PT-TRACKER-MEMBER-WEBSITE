# ====================
# DATABASE CONFIGURATION
# ====================
# Required: Database connection URL
# For SQLite (local development):
# DATABASE_URL=sqlite:///gym_tracker.db

# For PostgreSQL (production - Render, Aiven, etc.):
DATABASE_URL=postgresql://username:password@host:port/database_name
# Example: DATABASE_URL=postgresql://user:pass@dpg-xxx.oregon-postgres.render.com/dbname

# ====================
# SECURITY
# ====================
# Required: Secret key for session encryption (generate a random string)
SECRET_KEY=your-secret-key-here-change-this-in-production

# ====================
# EMAIL CONFIGURATION
# ====================
# Choose ONE email provider: SMTP, Brevo API, or Mailgun API

# --- Option 1: SMTP (Gmail, Outlook, etc.) ---
EMAIL_PROVIDER=smtp
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# --- Option 2: Brevo API (Recommended for cloud hosting) ---
# EMAIL_PROVIDER=brevo_api
# BREVO_API_KEY=your-brevo-api-key
# BREVO_SENDER_EMAIL=your-verified-sender@example.com
# BREVO_SENDER_NAME=Your Gym Name

# --- Option 3: Mailgun API ---
# EMAIL_PROVIDER=mailgun_api
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# ====================
# APPLICATION SETTINGS
# ====================
# Gym/Business name (appears in emails and UI)
GYM_NAME=NITRRO ZONE 360

# Developer name (appears in footer)
APP_DEVELOPER=NISHAD PATIL

# ====================
# SECURITY SETTINGS (Optional)
# ====================
# Login attempt limits
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# OTP settings
PASSWORD_RESET_OTP_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5

# ====================
# DEPLOYMENT SETTINGS (Optional)
# ====================
# Flask environment (development or production)
FLASK_ENV=production

# Port (default: 5001 for member portal, 5000 for trainer portal)
PORT=5001

# Session cookie security (set to true in production with HTTPS)
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=WARNING

# Rate limiting (optional)
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=500 per hour

# ====================
# PLATFORM-SPECIFIC (Auto-detected)
# ====================
# These are usually set automatically by hosting platforms
# VERCEL=true
# RENDER=true
